{
  "name": "iaris-desktop",
  "productName": "IARIS",
  "description": "IARIS - Intent-Aware Adaptive Resource Intelligence System",
  "author": "Anurag Mishra",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "lint": "eslint .",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "electron:dev": "node node_modules/vite/bin/vite.js build && node node_modules/electron/cli.js .",
    "electron:build": "node node_modules/vite/bin/vite.js build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false node node_modules/electron-builder/cli.js"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "puppeteer": "^24.42.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use-websocket": "^4.13.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.iaris.desktop",
    "productName": "IARIS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron/**",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../dist/iaris_engine.exe",
        "to": "iaris_engine.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "keywords": [],
  "license": "ISC"
}
